# LogicOS — Environment Configuration
# Copy this file to .env.local and set your values.

# ============================================
# PuddleJumper Backend (required)
# ============================================
# All provider API calls (GitHub, Microsoft, Google) are proxied through
# PuddleJumper server-side. Tokens never touch the browser.
#
# Development: http://localhost:3002
# Production:  https://api.publiclogic.org
VITE_PJ_API_URL=http://localhost:3002

# Local-only escape hatch for frontend work when PJ auth cookies are not
# available cross-site on localhost. Never enable this outside local dev.
# VITE_LOCAL_AUTH_BYPASS=1

# ============================================
# Puddles AI (required for /puddles)
# ============================================
ANTHROPIC_API_KEY=
PJ_MCP_URL=https://api.publiclogic.org/mcp/sse

# ============================================
# Optional default Google Drive parent folder for CAM/LIFE records.
LOGICOS_GOOGLE_ROOT_FOLDER_ID=
