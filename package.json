{
  "name": "puddlejumper-gpr",
  "version": "1.0.0",
  "private": true,
  "description": "PuddleJumper GPR — Government Process Runtime. The governed execution engine for PublicLogic municipal AI.",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "dev:pj": "turbo run dev --filter=@publiclogic/puddlejumper",
    "dev:vault": "turbo run dev --filter=@publiclogic/vault",
    "dev:logicos": "turbo run dev --filter=@gpr/logicos",
    "build:pj": "turbo run build --filter=@publiclogic/puddlejumper...",
    "start": "turbo run start --filter=@publiclogic/puddlejumper",
    "test:pj": "turbo run test --filter=@publiclogic/puddlejumper",
    "test:vault": "turbo run test --filter=@publiclogic/vault",
    "test:core": "turbo run test --filter=@publiclogic/core",
    "deploy:fly": "./scripts/deploy-fly.sh",
    "deploy:vercel": "./scripts/deploy-vercel.sh",
    "db:backup": "tsx apps/puddlejumper/src/api/sqliteMaintenance.ts backup",
    "smoke": "./scripts/smoke-test.sh"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.7.3",
    "tsx": "^4.19.2"
  }
}
