# ── PuddleJumper Environment ──
# Copy to .env.local and fill in values.

# Database
PJ_DB_PATH=./data/pj.db

# Auth (TBD — slot for provider)
# AUTH_SECRET=
# AUTH_URL=http://localhost:3000

# Anthropic (for Puddles chat)
ANTHROPIC_API_KEY=

# Vercel
VERCEL_URL=

# API
API_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Tenant (development default)
PJ_DEFAULT_TENANT_ID=dev-tenant
